<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="0">

    <!--
        PROJET - Lecture : visible uniquement par les membres de l'équipe projet.
        Les administrateurs (group_project_manager) ont leur règle native (1=1)
        combinée en OR → ils voient tout.
    -->
    <record model="ir.rule" id="is_project_read_equipe_rule">
        <field name="name">Projet : lecture restreinte à l'équipe projet</field>
        <field name="model_id" ref="project.model_project_project"/>
        <field name="domain_force">[('is_equipe_projet_ids', 'in', [user.id])]</field>
        <field name="groups" eval="[(4, ref('project.group_project_user'))]"/>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!--
        PROJET - Écriture/Création/Suppression : interdite aux utilisateurs non-administrateurs.
        (0=1) pour group_project_user, combiné en OR avec la règle admin (1=1)
        → admins peuvent écrire, simples utilisateurs ne peuvent pas.
    -->
    <record model="ir.rule" id="is_project_write_block_rule">
        <field name="name">Projet : écriture interdite aux non-administrateurs</field>
        <field name="model_id" ref="project.model_project_project"/>
        <field name="domain_force">[(0, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('project.group_project_user'))]"/>
        <field name="perm_read"   eval="False"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!--
        TÂCHE - Lecture + Écriture : restreintes aux membres de l'équipe du projet.
        Les administrateurs ont leur règle native (1=1) → ils voient et modifient tout.
    -->
    <record model="ir.rule" id="is_project_task_equipe_rule">
        <field name="name">Tâche : accès restreint à l'équipe du projet</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="domain_force">[('project_id.is_equipe_projet_ids', 'in', [user.id])]</field>
        <field name="groups" eval="[(4, ref('project.group_project_user'))]"/>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</data>
</odoo>
