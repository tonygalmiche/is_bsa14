<?xml version="1.0" encoding="utf-8"?>

<odoo>
     <data>
          <!-- is.pointage -->
          <record model="ir.ui.view" id="is_pointage_form_view">
               <field name="name">is_pointage_form_view</field>
               <field name="model">is.pointage</field>
               <field name="type">form</field>
               <field name="arch" type="xml">
                    <form string="Form">     
                    <sheet>
                         <group col="2" colspan="4">
                              <field name="name"/> 
                              <field name="employee"/> 
                              <field name="entree_sortie"/> 
                              <field name="pointeuse"/> 
                              <field name="commentaire" readonly="1"/> 
                         </group>
                    </sheet>
                    </form>
               </field>
          </record>
          <record model="ir.ui.view" id="is_pointage_tree_view">
               <field name="name">is_pointage_tree_view</field>
               <field name="model">is.pointage</field>
               <field name="type">tree</field>
                <field name="arch" type="xml">
                    <tree string="pointage" editable="top">
                         <field name="name"/>
                         <field name="employee"/>
                         <field name="entree_sortie"/>
                         <field name="pointeuse"   optional="hide" readonly="1"/>
                         <field name="commentaire" optional="hide" readonly="1"/>
                    </tree>
               </field>
          </record>
          <record model="ir.ui.view" id="is_pointage_filter_view" >
               <field name="name">is_pointage_filter_view</field>
               <field name="model">is.pointage</field>
               <field name="arch" type="xml">
                    <search string="Recherche">
                         <field name="name"/>
                         <field name="employee"/>
                         <field name="entree_sortie"/>
                         <field name="pointeuse"/> 
                         <field name="commentaire"/>
                         <group expand="0" string="Regroupé par...">
                              <filter name="group_pointeuse" string="Pointeuse" context="{'group_by':'pointeuse'}"/>
                              <filter name="group_employee"  string="Employé"   context="{'group_by':'employee'}"/>
                              <filter name="group_mois"      string="Mois"      context="{'group_by':'name:month'}"/>
                              <filter name="group_jour"      string="Jour"      context="{'group_by':'name:day'}"/>
                         </group>
                    </search>
               </field>
          </record>
          <record model="ir.actions.act_window" id="is_pointage_action">
               <field name="name">Pointages</field>
               <field name="res_model">is.pointage</field>
               <field name="view_mode">tree,form</field>
          </record>


          <!-- is.heure.effective -->
          <record model="ir.ui.view" id="is_heure_effective_tree_view">
               <field name="name">is_heure_effective_tree_view</field>
               <field name="model">is.heure.effective</field>
               <field name="type">tree</field>
                <field name="arch" type="xml">
                    <tree string="pointage" editable="top" decoration-danger="effectif_calcule!=effectif_reel">
                         <field name="name"                               readonly="1"/>
                         <field name="employee_id"               readonly="1"/>
                         <field name="department_id"          readonly="1"/>
                         <field name="theorique"                    readonly="1"/>
                         <field name="effectif_calcule" readonly="1"/>
                         <field name="effectif_reel"                                        />
                         <field name="balance_reelle"      readonly="1"/>
                         <field name="info_id"                                                       />
                         <field name="info_complementaire"                         />
                    </tree>
               </field>
          </record>
          <record model="ir.ui.view" id="is_heure_effective_filter_view" >
               <field name="name">is_heure_effective_filter_view</field>
               <field name="model">is.heure.effective</field>
               <field name="arch" type="xml">
                    <search string="Recherche">
                        <field name="name"/>
                        <field name="employee_id"/>
                        <field name="department_id"/>
                        <field name="info_id"/>
                        <group expand="0" string="Regroupé par...">
                            <filter name="group_mois"          string="Mois"        context="{'group_by':'name:month'}"/>
                            <filter name="group_jour"          string="Jour"        context="{'group_by':'name:day'}"/>
                            <filter name="group_employee_id"   string="Employé"     context="{'group_by':'employee_id'}"/>
                            <filter name="group_department_id" string="Département" context="{'group_by':'department_id'}"/>
                            <filter name="group_info_id"       string="Information" context="{'group_by':'info_id'}"/>
                        </group>
                    </search>
               </field>
          </record>
          <record model="ir.actions.act_window" id="is_heure_effective_action">
               <field name="name">Heures éffectives</field>
               <field name="res_model">is.heure.effective</field>
               <field name="view_mode">tree,form</field>
          </record>


          <!-- is_heure_effective_info -->
          <record model="ir.ui.view" id="is_heure_effective_info_tree_view">
               <field name="name">is_heure_effective_info_tree_view</field>
               <field name="model">is.heure.effective.info</field>
               <field name="type">tree</field>
                <field name="arch" type="xml">
                    <tree>
                         <field name="name"/>
                    </tree>
               </field>
          </record>
          <record model="ir.ui.view" id="is_heure_effective_info_form_view">
               <field name="name">is_heure_effective_info_tree_view</field>
               <field name="model">is.heure.effective.info</field>
               <field name="type">tree</field>
                <field name="arch" type="xml">
                    <form>     
                         <sheet>
                              <group>
                                   <field name="name"/>
                                   <field name="active"/>
                              </group>
                         </sheet>
                    </form>
               </field>
          </record>
          <record model="ir.actions.act_window" id="is_heure_effective_info_action">
               <field name="name">Informations</field>
               <field name="res_model">is.heure.effective.info</field>
               <field name="view_mode">tree,form</field>
          </record>


          <!-- is.suivi.heures -->
          <record model="ir.ui.view" id="is_suivi_heures_tree_view">
               <field name="name">is_suivi_heures_tree_view</field>
               <field name="model">is.suivi.heures</field>
               <field name="type">tree</field>
               <field name="arch" type="xml">
                    <tree string="Suivi des heures travaillées" create="false">
                         <field name="annee"          readonly="1"/>
                         <field name="mois_numero"    readonly="1"/>
                         <field name="mois"           readonly="1"/>
                         <field name="semaine"        readonly="1"/>
                         <field name="semaine_label"  readonly="1"/>
                         <field name="week_start"     readonly="1"/>
                         <field name="employee_id"    readonly="1"/>
                         <field name="department_id"  readonly="1"/>
                         <field name="balance_semaine" readonly="1"/>
                    </tree>
               </field>
          </record>
          <record model="ir.ui.view" id="is_suivi_heures_pivot_view">
               <field name="name">is_suivi_heures_pivot_view</field>
               <field name="model">is.suivi.heures</field>
               <field name="type">pivot</field>
               <field name="arch" type="xml">
                    <pivot string="Suivi des heures travaillées" default_order="balance_semaine desc">
                         <field name="employee_id"     type="row"/>
                         <field name="annee"           type="col"/>
                         <field name="balance_semaine" type="measure"/>
                    </pivot>
               </field>
          </record>
          <record model="ir.ui.view" id="is_suivi_heures_graph_view">
               <field name="name">is_suivi_heures_graph_view</field>
               <field name="model">is.suivi.heures</field>
               <field name="type">graph</field>
               <field name="arch" type="xml">
                    <graph string="Suivi des heures travaillées" type="bar" order="desc">
                         <field name="employee_id"     type="row"/>
                         <field name="balance_semaine" type="measure"/>
                    </graph>
               </field>
          </record>
          <record model="ir.ui.view" id="is_suivi_heures_filter_view">
               <field name="name">is_suivi_heures_filter_view</field>
               <field name="model">is.suivi.heures</field>
               <field name="arch" type="xml">
                    <search string="Recherche">
                         <field name="employee_id"/>
                         <field name="department_id"/>
                         <field name="annee"/>
                         <field name="mois_numero"/>
                         <field name="mois"/>
                         <field name="semaine"/>
                         <field name="semaine_label"/>
                         <separator/>
                         <filter name="filter_annee_courante" string="Année courante"
                                 domain="[('week_start','&gt;=', (context_today() + relativedelta(day=1,month=1)).strftime('%%Y-%%m-%%d')),
                                           ('week_start','&lt;=', (context_today() + relativedelta(day=31,month=12)).strftime('%%Y-%%m-%%d'))]"/>
                         <group expand="0" string="Regroupé par...">
                              <filter name="group_annee"         string="Année"       context="{'group_by':'annee'}"/>
                              <filter name="group_mois"          string="Mois"        context="{'group_by':'mois'}"/>
                              <filter name="group_semaine_label" string="Semaine"     context="{'group_by':'semaine_label'}"/>
                              <filter name="group_employee_id"   string="Employé"     context="{'group_by':'employee_id'}"/>
                              <filter name="group_department_id" string="Département" context="{'group_by':'department_id'}"/>
                         </group>
                    </search>
               </field>
          </record>
          <record model="ir.actions.act_window" id="is_suivi_heures_action">
               <field name="name">Suivi des heures travaillées</field>
               <field name="res_model">is.suivi.heures</field>
               <field name="view_mode">tree,pivot,graph</field>
          </record>
          <record id="suivi_heures_cron_nuit" model="ir.cron">
               <field name="name">Suivi heures travaillées — recalcul nuit (10 semaines)</field>
               <field name="model_id" ref="model_is_suivi_heures"/>
               <field name="state">code</field>
               <field name="code">model.action_calculer(nb_semaines=10)</field>
               <field name="interval_number">1</field>
               <field name="interval_type">days</field>
               <field name="numbercall">-1</field>
               <field name="active">True</field>
          </record>
          <record id="suivi_heures_cron_mensuel" model="ir.cron">
               <field name="name">Suivi heures travaillées — recalcul complet mensuel</field>
               <field name="model_id" ref="model_is_suivi_heures"/>
               <field name="state">code</field>
               <field name="code">model.action_calculer(nb_semaines=None)</field>
               <field name="interval_number">1</field>
               <field name="interval_type">months</field>
               <field name="numbercall">-1</field>
               <field name="active">True</field>
          </record>
     </data>
</odoo>
